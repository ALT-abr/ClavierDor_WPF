<Page x:Class="clavierdor.Views.Pages.History"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#04111D">
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#04111D" Offset="0" />
            <GradientStop Color="#071726" Offset="0.5" />
            <GradientStop Color="#04111D" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GoldBrush" Color="#E8B84A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0A1725" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#162330" />
        <SolidColorBrush x:Key="RowLineBrush" Color="#2B3744" />
        <SolidColorBrush x:Key="MutedBrush" Color="#B7B7B7" />

        <Style x:Key="HeaderCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BodyCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F3F3" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid Margin="42,30,42,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="110" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="92"
                            Height="92"
                            Margin="0,0,24,0"
                            BorderBrush="{StaticResource GoldBrush}"
                            BorderThickness="2"
                            CornerRadius="46">
                        <iconPacks:PackIconMaterial Kind="TrophyOutline"
                                                    Width="46"
                                                    Height="46"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource GoldBrush}" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HISTORIQUE DES PARTIES"
                                   Foreground="White"
                                   FontFamily="Georgia"
                                   FontSize="38"
                                   FontWeight="Bold" />
                        <Border Width="470"
                                Height="1.4"
                                Margin="2,8,0,8"
                                HorizontalAlignment="Left"
                                Background="#9A7B3D" />
                        <TextBlock Foreground="{StaticResource MutedBrush}"
                                   FontSize="20"
                                   Text="Consultez toutes vos parties jouees" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Width="254"
                        Height="60"
                        VerticalAlignment="Top"
                        Style="{StaticResource BackButtonStyle}"
                        Click="BackHome_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="0,0,12,0"
                                                    Foreground="{StaticResource GoldBrush}" />
                        <TextBlock Text="Retour a l'accueil" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,26,0,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#8C6A33"
                    BorderThickness="1.2"
                    CornerRadius="16"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="82" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderBrush}"
                            CornerRadius="16,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="1.08*" />
                                <ColumnDefinition Width="1.04*" />
                                <ColumnDefinition Width="1.06*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Margin="36,0,0,0"
                                        VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Account"
                                                            Width="25"
                                                            Height="25"
                                                            Margin="0,0,12,0"
                                                            Foreground="{StaticResource GoldBrush}" />
                                <TextBlock Text="NOM DU JOUEUR" Style="{StaticResource HeaderCellTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="TrophyOutline"
                                                            Width="25"
                                                            Height="25"
                                                            Margin="0,0,12,0"
                                                            Foreground="{StaticResource GoldBrush}" />
                                <TextBlock Text="SCORE" Style="{StaticResource HeaderCellTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="FlagOutline"
                                                            Width="23"
                                                            Height="23"
                                                            Margin="0,0,12,0"
                                                            Foreground="{StaticResource GoldBrush}" />
                                <TextBlock Text="STATUT" Style="{StaticResource HeaderCellTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="CalendarMonthOutline"
                                                            Width="23"
                                                            Height="23"
                                                            Margin="0,0,12,0"
                                                            Foreground="{StaticResource GoldBrush}" />
                                <TextBlock Text="DATE" Style="{StaticResource HeaderCellTextStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Histories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="76"
                                        BorderBrush="{StaticResource RowLineBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="1.08*" />
                                            <ColumnDefinition Width="1.04*" />
                                            <ColumnDefinition Width="1.06*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Margin="36,0,0,0"
                                                   Style="{StaticResource BodyCellTextStyle}"
                                                   Text="{Binding PlayerName}" />

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource GoldBrush}"
                                                       Text="{Binding Score}" />
                                            <TextBlock FontSize="17"
                                                       Foreground="White"
                                                       Text=" / 500" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource BodyCellTextStyle}"
                                                   Text="{Binding StatusText}" />

                                        <TextBlock Grid.Column="3"
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource BodyCellTextStyle}"
                                                   Text="{Binding DateText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
