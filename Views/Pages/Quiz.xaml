<Page x:Class="clavierdor.Views.Pages.Quiz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#07111A">
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07111A" Offset="0" />
            <GradientStop Color="#0B1722" Offset="0.5" />
            <GradientStop Color="#091018" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GoldBrush" Color="#E7B44C" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111821" />
        <SolidColorBrush x:Key="CardBrush" Color="#16212C" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F1E9" />
        <SolidColorBrush x:Key="MutedBrush" Color="#B8C0CA" />

        <Style x:Key="AnswerButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="#405062" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="24,18">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid Margin="42,28,42,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Georgia"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}"
                               Text="QUIZ CLAVIER D'OR" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="18"
                               Foreground="{StaticResource MutedBrush}"
                               Text="{Binding PlayerText, StringFormat=Joueur : {0}}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="0,0,16,0"
                        Padding="18,10"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource GoldBrush}"
                        BorderThickness="1.2"
                        CornerRadius="14">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldBrush}"
                               Text="{Binding ScoreText, StringFormat=Score : {0}}" />
                </Border>

                <Border Grid.Column="2"
                        Padding="18,10"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="#4C6176"
                        BorderThickness="1.2"
                        CornerRadius="14">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="{Binding ProgressText}" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,24,0,24"
                    Padding="34"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="1.4"
                    CornerRadius="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="{Binding CategoryText, StringFormat=Categorie : {0}}" />
                        <TextBlock x:Name="BossTitleTextBlock"
                                   Margin="0,10,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}"
                                   Visibility="Collapsed"
                                   Text="{Binding BossTitle}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,28,0,24"
                               TextWrapping="Wrap"
                               FontSize="31"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               Text="{Binding QuestionText}" />

                    <TextBlock x:Name="CompletedTextBlock"
                               Grid.Row="2"
                               Margin="0,10,0,0"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GoldBrush}"
                               Text="{Binding CompleteMessage}"
                               Visibility="Collapsed" />

                    <UniformGrid Grid.Row="3"
                                 Columns="1"
                                 Margin="0,8,0,0">
                        <Button x:Name="OptionAButton"
                                Margin="0,0,0,16"
                                Style="{StaticResource AnswerButtonStyle}"
                                Click="OptionAButton_Click">
                            <TextBlock Text="{Binding OptionAText, StringFormat=A. {0}}" TextWrapping="Wrap" />
                        </Button>
                        <Button x:Name="OptionBButton"
                                Margin="0,0,0,16"
                                Style="{StaticResource AnswerButtonStyle}"
                                Click="OptionBButton_Click">
                            <TextBlock Text="{Binding OptionBText, StringFormat=B. {0}}" TextWrapping="Wrap" />
                        </Button>
                        <Button x:Name="OptionCButton"
                                Style="{StaticResource AnswerButtonStyle}"
                                Click="OptionCButton_Click">
                            <TextBlock Text="{Binding OptionCText, StringFormat=C. {0}}" TextWrapping="Wrap" />
                        </Button>
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="16"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Question : +3 | Boss : +30 / -10 | Boss final : +50 / -20 | Max : 500" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="{StaticResource GoldBrush}"
                               Text="{Binding HintText}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Padding="22,12"
                        Background="#12202B"
                        BorderBrush="#6E8BA8"
                        BorderThickness="1.2"
                        Foreground="#E7EEF6"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="{Binding CanUsePouvoir}"
                        Click="UsePouvoirButton_Click"
                        Content="{Binding PouvoirButtonText}" />

                <Button Grid.Column="3"
                        Padding="22,12"
                        Background="#0D141B"
                        BorderBrush="{StaticResource GoldBrush}"
                        BorderThickness="1.2"
                        Foreground="{StaticResource GoldBrush}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BackHomeButton_Click"
                        Content="Quitter" />
            </Grid>
        </Grid>
    </Grid>
</Page>
