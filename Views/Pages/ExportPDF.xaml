<Page x:Class="clavierdor.Views.Pages.ExportPDF"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ExportPDF"
      Background="#F5F6FB">
    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4338CA" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#26235D" />
        <SolidColorBrush x:Key="PageBrush" Color="#F5F6FB" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DBE8" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource PrimaryBrush}"
                                CornerRadius="10"
                                Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="146" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="28"
                               Foreground="White"
                               Text="&#xEA90;" />
                    <TextBlock Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="Exporter un rapport PDF" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="44"
                        Height="44"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               Text="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="34,24,34,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="{StaticResource PrimaryBrush}"
                           Text="&#xE716;" />
                <TextBlock Margin="14,0,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Text="Selectionner le joueur" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,18,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="224" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontSize="18"
                           Text="Nom du joueur :" />

                <ComboBox x:Name="PlayerComboBox"
                          Grid.Column="1"
                          Height="54"
                          Padding="14,6"
                          FontSize="18"
                          ItemsSource="{Binding Players}"
                          SelectedItem="{Binding SelectedPlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="3"
                        Height="54"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ExportButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,12,0"
                                   FontSize="18"
                                   Text="&#xEA90;" />
                        <TextBlock Text="Exporter en PDF" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="2" Height="1" Background="#E3E5EF" VerticalAlignment="Bottom" />
        </Grid>

        <Grid Grid.Row="2" Margin="34,0,34,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="{StaticResource PrimaryBrush}"
                           Text="&#xE8A7;" />
                <TextBlock Margin="14,0,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Text="Apercu du rapport" />
            </StackPanel>

            <Viewbox Grid.Row="1"
                     Stretch="Uniform"
                     StretchDirection="Both"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top">
                <Border Width="1240"
                        Height="760"
                        Padding="42"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Border BorderBrush="#E6E8F1"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <Image Source="pack://application:,,,/Assets/Images/exmplpdf.png"
                               Stretch="Uniform" />
                    </Border>
                </Border>
            </Viewbox>
        </Grid>
    </Grid>
</Page>
