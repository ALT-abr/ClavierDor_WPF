<Page x:Class="clavierdor.Views.Pages.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Home"
      Background="#070707">
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050505" Offset="0" />
            <GradientStop Color="#101010" Offset="0.45" />
            <GradientStop Color="#070707" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GoldBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF4C96A" Offset="0" />
            <GradientStop Color="#FFD7A73A" Offset="0.45" />
            <GradientStop Color="#FF8E6116" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GoldTextBrush" Color="#FFF2CC70" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFF7EFD6" />
        <SolidColorBrush x:Key="CardFillBrush" Color="#101113" />
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#FFCC9A33" />
        <DropShadowEffect x:Key="GoldGlow" BlurRadius="28" ShadowDepth="0" Color="#C8D7A73A" Opacity="0.85" />
        <DropShadowEffect x:Key="SoftGlow" BlurRadius="18" ShadowDepth="0" Color="#80D7A73A" Opacity="0.7" />

        <Style x:Key="ActionCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardFillBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#55D7A73A" Opacity="0.5" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#A0E5B64F" Opacity="0.95" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.985" ScaleY="0.985" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}" ClipToBounds="True">
        <Canvas IsHitTestVisible="False" Opacity="0.15">
            <TextBlock Canvas.Left="25" Canvas.Top="70"
                       Foreground="#75B7BEC8"
                       FontFamily="Consolas"
                       FontSize="21"
                       Text="#include &lt;iostream&gt;&#10;using namespace std;&#10;&#10;int main() {&#10;   cout &lt;&lt; &quot;Clavier d'Or&quot;;&#10;   return 0;&#10;}" />
            <TextBlock Canvas.Right="40" Canvas.Top="120"
                       Foreground="#75B7BEC8"
                       FontFamily="Consolas"
                       FontSize="21"
                       Text="function solve() {&#10;  let score = 0;&#10;  return score;&#10;}" />
            <TextBlock Canvas.Left="40" Canvas.Bottom="40"
                       Foreground="#50D7A73A"
                       FontFamily="Consolas"
                       FontSize="26"
                       Text="0101001 0011 1010 1101" />
            <TextBlock Canvas.Right="30" Canvas.Bottom="45"
                       Foreground="#50D7A73A"
                       FontFamily="Consolas"
                       FontSize="26"
                       Text="0010 1111 0101 0100" />
        </Canvas>

        <Viewbox Stretch="Uniform" StretchDirection="Both">
            <Grid Width="1600" Height="900">
                <Grid Margin="46,26,46,26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="270" />
                        <RowDefinition Height="390" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="♛"
                                   FontSize="78"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   Effect="{StaticResource GoldGlow}" />
                        <TextBlock Text="CLAVIER D'OR"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   FontFamily="Times New Roman"
                                   FontSize="90"
                                   FontWeight="SemiBold"
                                   Effect="{StaticResource GoldGlow}" />
                        <TextBlock Text="LE QUIZ DES VRAIS DEVELOPPEURS"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   Foreground="#FFF0E6CC"
                                   FontFamily="Georgia"
                                   FontSize="26" />
                        <Border Width="340"
                                Height="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Center"
                                Background="{StaticResource GoldBrush}"
                                CornerRadius="1" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <Button Style="{StaticResource ActionCardButtonStyle}" Margin="16" Click="PlayButton_Click">
                            <Grid Width="300" Height="360">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🎮" HorizontalAlignment="Center" FontSize="92" Effect="{StaticResource SoftGlow}" />
                                    <TextBlock Text="JOUER"
                                               Margin="0,28,0,8"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Commencer une&#10;nouvelle partie"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource GoldTextBrush}"
                                               FontSize="22" />
                                    <Border Width="78" Height="3" Margin="0,30,0,0" HorizontalAlignment="Center" Background="{StaticResource GoldBrush}" CornerRadius="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource ActionCardButtonStyle}" Margin="16" Click="ResumeButton_Click">
                            <Grid Width="300" Height="360">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="↻"
                                               HorizontalAlignment="Center"
                                               FontSize="100"
                                               Foreground="{StaticResource GoldTextBrush}"
                                               Effect="{StaticResource SoftGlow}" />
                                    <TextBlock Text="REPRENDRE"
                                               Margin="0,22,0,8"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Georgia"
                                               FontSize="32"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Reprendre une&#10;partie en cours"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource GoldTextBrush}"
                                               FontSize="22" />
                                    <Border Width="78" Height="3" Margin="0,30,0,0" HorizontalAlignment="Center" Background="{StaticResource GoldBrush}" CornerRadius="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource ActionCardButtonStyle}" Margin="16" Click="HistoryButton_Click">
                            <Grid Width="300" Height="360">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🏆" HorizontalAlignment="Center" FontSize="92" Effect="{StaticResource SoftGlow}" />
                                    <TextBlock Text="HISTORIQUE"
                                               Margin="0,28,0,8"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Georgia"
                                               FontSize="30"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Voir vos anciennes&#10;parties et scores"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource GoldTextBrush}"
                                               FontSize="22" />
                                    <Border Width="78" Height="3" Margin="0,30,0,0" HorizontalAlignment="Center" Background="{StaticResource GoldBrush}" CornerRadius="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource ActionCardButtonStyle}" Margin="16" Click="ExportPdfButton_Click">
                            <Grid Width="300" Height="360">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📄" HorizontalAlignment="Center" FontSize="92" Effect="{StaticResource SoftGlow}" />
                                    <TextBlock Text="EXPORT PDF"
                                               Margin="0,28,0,8"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Georgia"
                                               FontSize="30"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Exporter vos scores&#10;en PDF"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource GoldTextBrush}"
                                               FontSize="22" />
                                    <Border Width="78" Height="3" Margin="0,30,0,0" HorizontalAlignment="Center" Background="{StaticResource GoldBrush}" CornerRadius="2" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </UniformGrid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="34,16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="28"
                            BorderBrush="#AAAE7F2F"
                            BorderThickness="1.4"
                            Background="#111214">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#80D7A73A" Opacity="0.65" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆" FontSize="34" VerticalAlignment="Center" Foreground="{StaticResource GoldTextBrush}" />
                            <TextBlock Text="CODE. REFLECHIS. GAGNE."
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource GoldTextBrush}"
                                       FontFamily="Georgia"
                                       FontSize="20" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</Page>
