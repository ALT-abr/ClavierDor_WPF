<Window x:Class="clavierdor.Views.Dialogs.Play"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouvelle partie"
        Width="840"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="GoldBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF3CC72" Offset="0" />
            <GradientStop Color="#FFD9A93B" Offset="0.45" />
            <GradientStop Color="#FF8E6116" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GoldTextBrush" Color="#FFF2CC70" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFF4F0E8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0E1115" />
        <SolidColorBrush x:Key="FieldBrush" Color="#14181D" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#4B525C" />
        <SolidColorBrush x:Key="FrontBrush" Color="#4B8BFF" />
        <SolidColorBrush x:Key="BackBrush" Color="#62E45B" />
        <SolidColorBrush x:Key="MobileBrush" Color="#C154FF" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF3F0E8" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#0D1014"
                                BorderBrush="#996D4A12"
                                BorderThickness="1.3"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#16110A" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14"
                                BorderBrush="#FFF6D98B"
                                BorderThickness="1.1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFE0AE3F" Offset="0" />
                                    <GradientStop Color="#FFF8D267" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Foreground" Value="{StaticResource GoldTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#120F0A"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="26">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleCardStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder"
                                Padding="16"
                                Background="#11161A"
                                BorderBrush="#4B525C"
                                BorderThickness="1.2"
                                CornerRadius="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#8B939F" />
                                <Setter TargetName="CardBorder" Property="Background" Value="#151D26" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="CardBorder" Property="Background" Value="#192430" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="680"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource RoundIconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               Text="&#xE711;" />
                </Button>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center">
                    <TextBlock Text="♛"
                               HorizontalAlignment="Center"
                               FontSize="40"
                               Foreground="{StaticResource GoldTextBrush}" />
                    <TextBlock Text="NOUVELLE PARTIE"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource GoldTextBrush}"
                               FontFamily="Georgia"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Preparez-vous a relever le defi !"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="15" />
                    <Border Width="150"
                            Height="2"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Background="{StaticResource GoldBrush}"
                            CornerRadius="1" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,6,10,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,8,0"
                                   FontSize="16"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   Text="&#xE77B;" />
                        <TextBlock Text="NOM DU JOUEUR"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="10,0,10,18"
                        Padding="16,10"
                        Background="{StaticResource FieldBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        BorderThickness="1.2"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="4,0,14,0"
                                   VerticalAlignment="Center"
                                   FontSize="20"
                                   Foreground="#FFCFCBC6"
                                   Text="&#xE77B;" />
                        <TextBox x:Name="PlayerNameTextBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#FFF3F0E8"
                                 CaretBrush="{StaticResource GoldTextBrush}"
                                 FontSize="18"
                                 VerticalContentAlignment="Center"
                                 Text="Entrez votre nom"
                                 GotFocus="PlayerNameTextBox_GotFocus"
                                 LostFocus="PlayerNameTextBox_LostFocus" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="10,0,10,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,8,0"
                                   FontSize="16"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   Text="&#xE72E;" />
                        <TextBlock Text="CHOISISSEZ VOTRE ROLE"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <UniformGrid Grid.Row="4"
                             Columns="3"
                             Margin="10,0,10,18">
                    <RadioButton x:Name="FrontRoleRadioButton"
                                 GroupName="Roles"
                                 Margin="0,0,10,0"
                                 Style="{StaticResource RoleCardStyle}"
                                 Tag="{StaticResource FrontBrush}"
                                 IsChecked="True">
                        <StackPanel>
                            <TextBlock Text="&lt;/&gt;"
                                       HorizontalAlignment="Center"
                                       FontSize="30"
                                       Foreground="{StaticResource FrontBrush}" />
                            <TextBlock Text="DEVELOPPEUR FRONT"
                                       Margin="0,10,0,8"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource FrontBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Specialiste de l'interface&#10;et de l'experience utilisateur."
                                       TextAlignment="Center"
                                       Foreground="#FFF0ECE4"
                                       FontSize="11"
                                       LineHeight="20" />
                            <Border Width="70"
                                    Height="1.5"
                                    Margin="0,12,0,12"
                                    HorizontalAlignment="Center"
                                    Background="#4B525C" />
                            <TextBlock Text="POUVOIR :"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource FrontBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Changer de question"
                                       Margin="0,6,0,12"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource FrontBrush}"
                                       FontSize="11" />
                            <TextBlock Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#D8E3EF"
                                       Text="Cliquez pour choisir" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="BackRoleRadioButton"
                                 GroupName="Roles"
                                 Margin="5,0"
                                 Style="{StaticResource RoleCardStyle}"
                                 Tag="{StaticResource BackBrush}">
                        <StackPanel>
                            <TextBlock Text="☰"
                                       HorizontalAlignment="Center"
                                       FontSize="30"
                                       Foreground="{StaticResource BackBrush}" />
                            <TextBlock Text="DEVELOPPEUR BACK"
                                       Margin="0,10,0,8"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BackBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Maitre de la logique&#10;et des donnees."
                                       TextAlignment="Center"
                                       Foreground="#FFF0ECE4"
                                       FontSize="11"
                                       LineHeight="20" />
                            <Border Width="70"
                                    Height="1.5"
                                    Margin="0,12,0,12"
                                    HorizontalAlignment="Center"
                                    Background="#4B525C" />
                            <TextBlock Text="POUVOIR :"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BackBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Rattrapage automatique"
                                       Margin="0,6,0,12"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource BackBrush}"
                                       FontSize="11" />
                            <TextBlock Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#D8E3EF"
                                       Text="Cliquez pour choisir" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="MobileRoleRadioButton"
                                 GroupName="Roles"
                                 Margin="10,0,0,0"
                                 Style="{StaticResource RoleCardStyle}"
                                 Tag="{StaticResource MobileBrush}">
                        <StackPanel>
                            <TextBlock Text="◫"
                                       HorizontalAlignment="Center"
                                       FontSize="30"
                                       Foreground="{StaticResource MobileBrush}" />
                            <TextBlock Text="DEVELOPPEUR MOBILE"
                                       Margin="0,10,0,8"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource MobileBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Expert des applications&#10;mobiles."
                                       TextAlignment="Center"
                                       Foreground="#FFF0ECE4"
                                       FontSize="11"
                                       LineHeight="20" />
                            <Border Width="70"
                                    Height="1.5"
                                    Margin="0,12,0,12"
                                    HorizontalAlignment="Center"
                                    Background="#4B525C" />
                            <TextBlock Text="POUVOIR :"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource MobileBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Obtenir un indice"
                                       Margin="0,6,0,12"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource MobileBrush}"
                                       FontSize="11" />
                            <TextBlock Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#D8E3EF"
                                       Text="Cliquez pour choisir" />
                        </StackPanel>
                    </RadioButton>
                </UniformGrid>

                <Grid Grid.Row="5" Margin="10,0,10,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="1.5" VerticalAlignment="Center" Background="#6D7A30" />
                    <TextBlock Grid.Column="1"
                               Margin="12,0"
                               Text="♛"
                               FontSize="18"
                               Foreground="{StaticResource GoldTextBrush}" />
                    <Border Grid.Column="2" Height="1.5" VerticalAlignment="Center" Background="#6D7A30" />
                </Grid>

                <Grid Grid.Row="6" Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="66"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_Click"
                            Content="ANNULER" />

                    <Button Grid.Column="2"
                            Height="66"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="StartButton_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,14,0"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Text="&#xE768;" />
                            <TextBlock Text="COMMENCER" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
