<Window x:Class="clavierdor.Views.Dialogs.Resume"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reprendre une partie"
        Width="980"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="GoldBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF3CC72" Offset="0" />
            <GradientStop Color="#FFD9A93B" Offset="0.45" />
            <GradientStop Color="#FF8E6116" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GoldTextBrush" Color="#FFF2CC70" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFF4F0E8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0E1115" />
        <SolidColorBrush x:Key="FieldBrush" Color="#14181D" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#4B525C" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF3F0E8" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#0D1014"
                                BorderBrush="#996D4A12"
                                BorderThickness="1.3"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#16110A" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16"
                                BorderBrush="#FFF6D98B"
                                BorderThickness="1.1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFE0AE3F" Offset="0" />
                                    <GradientStop Color="#FFF8D267" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
            <Setter Property="BorderThickness" Value="1.3" />
            <Setter Property="Foreground" Value="{StaticResource GoldTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#120F0A"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="30">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="820"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.6"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource RoundIconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="22"
                               Text="&#xE711;" />
                </Button>

                <StackPanel Grid.Row="0"
                            Margin="0,6,0,10"
                            HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               HorizontalAlignment="Center"
                               FontSize="52"
                               Foreground="{StaticResource GoldTextBrush}"
                               Text="&#xE72C;" />
                    <TextBlock Text="REPRENDRE UNE PARTIE"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource GoldTextBrush}"
                               FontFamily="Georgia"
                               FontSize="34"
                               FontWeight="SemiBold" />
                    <Border Width="250"
                            Height="2"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            Background="{StaticResource GoldBrush}"
                            CornerRadius="1" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,24"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="18"
                           Text="Entrez le nom du joueur pour retrouver&#10;votre partie en cours." />

                <StackPanel Grid.Row="2" Margin="18,0,18,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,10,0"
                                   FontSize="18"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   Text="&#xE77B;" />
                        <TextBlock Text="NOM DU JOUEUR"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="3"
                        Margin="18,0,18,24"
                        Padding="18,12"
                        Background="{StaticResource FieldBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        BorderThickness="1.2"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Margin="4,0,16,0"
                                   VerticalAlignment="Center"
                                   FontSize="22"
                                   Foreground="#FFCFCBC6"
                                   Text="&#xE77B;" />
                        <TextBox x:Name="PlayerNameTextBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#FFF3F0E8"
                                 CaretBrush="{StaticResource GoldTextBrush}"
                                 FontSize="20"
                                 VerticalContentAlignment="Center"
                                 Text="Entrez le nom du joueur"
                                 GotFocus="PlayerNameTextBox_GotFocus"
                                 LostFocus="PlayerNameTextBox_LostFocus" />
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Margin="18,0,18,26"
                        Padding="22,18"
                        Background="#10151B"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        BorderThickness="1.2"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="46"
                                Height="46"
                                Margin="0,0,16,0"
                                VerticalAlignment="Top"
                                BorderBrush="#3C89FF"
                                BorderThickness="2"
                                CornerRadius="23">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#56A0FF"
                                       Text="i" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   TextWrapping="Wrap"
                                   Foreground="#FFF3F0E8"
                                   FontSize="17"
                                   LineHeight="28"
                                   Text="Seules les parties non terminees peuvent etre reprises.&#10;Si aucune partie en cours n'est trouvee, un message vous sera affiche." />
                    </Grid>
                </Border>

                <Grid Grid.Row="5" Margin="18,0,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="84"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_Click"
                            Content="ANNULER" />

                    <Button Grid.Column="2"
                            Height="84"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OkButton_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,16,0"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       Text="&#xE768;" />
                            <TextBlock Text="OK" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
